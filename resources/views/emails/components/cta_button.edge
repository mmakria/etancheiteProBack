{{-- CTA Button Component
     @param href - Button URL
     @param label - Button text
--}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td align="center">
      <!--[if mso]>
      <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ href }}" style="height:48px;v-text-anchor:middle;width:260px;" arcsize="10%" strokecolor="#D97706" fillcolor="#D97706">
        <w:anchorlock/>
        <center style="color:#ffffff;font-family:Inter,Arial,sans-serif;font-size:16px;font-weight:bold;">{{ label }}</center>
      </v:roundrect>
      <![endif]-->
      <!--[if !mso]><!-->
      <a href="{{ href }}" target="_blank" style="display: inline-block; background-color: #D97706; color: #ffffff; font-size: 16px; font-weight: 700; text-decoration: none; padding: 14px 32px; border-radius: 6px; text-align: center; mso-hide: all;">{{ label }}</a>
      <!--<![endif]-->
    </td>
  </tr>
</table>
